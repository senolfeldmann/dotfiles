# Cross-platform (macOS and Linuxbrew): CLI media tools as formulae so
# convert/mogrify and mkvmerge/mkvextract sit directly in PATH for scripting;
# a Flatpak would hide them behind `flatpak run --command=`.
brew "imagemagick"
brew "mkvtoolnix"

if OS.mac?
    # Runtimes
    cask "crossover"

    # Entertainment
    cask "steam"
    cask "playcover-community"

    # Multimedia
    cask "plex"
    cask "iina"
    cask "vlc"
    mas "ApolloOne", id: 1044484672

    # Engineering
    cask "bambu-studio"

    # Misc Tools
    cask "balenaetcher"
    cask "unified-remote"

    # Multimedia tools
    cask "handbrake"
    cask "mediainfo"
    # GUI app; the CLI tools come from the cross-platform formula above
    cask "mkvtoolnix"

    # Downloader
    cask "jdownloader"

    # Communication
    cask "discord"

    # System
    cask "appcleaner"
    cask "lulu"
    # for nsusbloader
    brew "libusb"


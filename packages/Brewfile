if OS.mac?
  # Docker: Rancher Desktop provides the VM/daemon AND its own matching
  # CLIs (docker, buildx, compose, kubectl, nerdctl, helm) in ~/.rd/bin;
  # separate brew formulae would just drift against the daemon version.
  # ~/.rd/bin is added to PATH in .zshrc. One-time app setting: set
  # Preferences -> Application -> Environment -> Path Management to
  # "Manual", so the app never edits the symlinked rc files itself.
  cask "rancher"

